<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:background="#F5F7FB"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sistema de Localización"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#0E6E6E"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="10dp" />

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:scaleType="centerInside"
        app:layout_constraintTop_toBottomOf="@+id/titleText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/buttonGroup" />

    <LinearLayout
        android:id="@+id/buttonGroup"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="10dp">

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchTiempoReal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Modo Tiempo Real (2 seg)"
            android:textSize="18sp"
            android:padding="12dp"
            android:textColor="#333333"
            android:layout_marginBottom="8dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchModoAhorro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Modo Ahorro (10 seg)"
            android:textSize="18sp"
            android:padding="12dp"
            android:textColor="#333333"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/button2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="VER MAPA DE RASTREO"
            android:backgroundTint="#43A047"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/buttonDetener"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DETENER RASTREO"
            android:backgroundTint="#D32F2F" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>